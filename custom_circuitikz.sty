%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% Custom Circuit Macros %%
%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\newcommand{\CircuitHeight}{2}
\newcommand{\CircuitWidth}{1.33}
\newcommand{\CircuitSeparation}{2.5*\CircuitWidth}

\newcommand\Bipole[3]{
    \draw 
        (0, 0) #1 to 
        ++(\CircuitWidth/2, 0) to #2
        ++(0, -\CircuitHeight) to 
        ++(-\CircuitWidth, 0) to #3
        ++(0, \CircuitHeight) to [short, -*] 
        ++(\CircuitWidth/2, 0) 
        ;
}

\newcommand\Quadrupole[9]{
    %% Capacitors %%
    \begin{scope}#1
        \draw
            (0, \CircuitHeight) to #2
            (0, 0) to
            (0, -\CircuitHeight)
            ;
        
        \draw
            (-\CircuitHeight, 0) to 
            (-\CircuitHeight/4, 0) to [crossing] 
            (\CircuitHeight/4, 0) to #3
            (3*\CircuitHeight/4, 0) to 
            (\CircuitHeight, 0)
            ;
    \end{scope}

    %% Junctions %%
    \begin{scope}#4
        \draw
            (0, \CircuitHeight) to #5
            (\CircuitHeight, 0)
            (0, -\CircuitHeight) to #6
            (-\CircuitHeight, 0)
            ;
    \end{scope}
    
    %% Inductors %%
    \begin{scope}#7
        \draw
            (-\CircuitHeight, 0) to #8
            (0, \CircuitHeight)
            (\CircuitHeight, 0) to #9
            (0, -\CircuitHeight) 
            ;
    \end{scope}
}

\newcommand\QuadrupoleNodes[5]{
    \begin{scope}#1
        %% Nodes %%
        \draw
            (0, \CircuitHeight) #2
            (\CircuitHeight, 0) #3
            (-\CircuitHeight, 0) #4 
            (0, -\CircuitHeight) #5
            ;
    \end{scope}
}
